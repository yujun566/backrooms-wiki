let currentTab = 'levels';
let currentIndex = -1;

function nl2br(s) {
  return s ? s.replace(/\n/g, '<br>') : '';
}

function getDangerClass(danger) {
  if (danger.includes('Class 0')) return 'danger-class0';
  if (danger.includes('Class 1')) return 'danger-class1';
  if (danger.includes('Class 2')) return 'danger-class2';
  if (danger.includes('Class 3')) return 'danger-class3';
  if (danger.includes('Class 4')) return 'danger-class4';
  if (danger.includes('Class 5') || danger.includes('불가능')) return 'danger-class5';
  return '';
}

function getTagClass(danger) {
  if (danger.includes('Class 0')) return 'tag-danger-0';
  if (danger.includes('Class 1')) return 'tag-danger-1';
  if (danger.includes('Class 2')) return 'tag-danger-2';
  if (danger.includes('Class 3')) return 'tag-danger-3';
  if (danger.includes('Class 4')) return 'tag-danger-4';
  if (danger.includes('Class 5') || danger.includes('불가능')) return 'tag-danger-5';
  return 'tag-default';
}

function getEntityDangerClass(danger) {
  if (danger.includes('Inhuman') || danger.includes('최상급')) return 'entity-inhuman';
  if (danger.includes('Hostile') || danger.includes('위험')) return 'entity-hostile';
  return 'entity-neutral';
}

function switchTab(tab) {
  currentTab = tab;
  currentIndex = -1;
  document.querySelectorAll('.nav-tab').forEach((btn,i) => {
    btn.classList.toggle('active', ['levels','entities','items','behinds'][i] === tab);
  });
  document.getElementById('searchInput').value = '';
  renderList();
  showWelcome();
}

function renderList(filter='') {
  const list = document.getElementById('sidebarList');
  const count = document.getElementById('sidebarCount');
  let items = [];
  let html = '';
  filter = filter.toLowerCase();

  if (currentTab === 'levels') {
    items = LEVELS.filter(l => !filter || 
      ('level ' + l.num).includes(filter) ||
      l.name.toLowerCase().includes(filter) ||
      l.danger.toLowerCase().includes(filter));
    count.textContent = `레벨 ${items.length}개`;
    items.forEach((l,i) => {
      const cls = getTagClass(l.danger);
      html += `<div class="sidebar-item${currentIndex===i?' active':''}" onclick="showLevel(${l.num})">
        <span class="item-num">${l.num}</span>
        <span class="item-name">${l.name}</span>
      </div>`;
    });
  } else if (currentTab === 'entities') {
    items = ENTITIES.filter(e => !filter ||
      ('entity #' + e.num).includes(filter) ||
      e.name.toLowerCase().includes(filter) ||
      e.danger.toLowerCase().includes(filter) ||
      e.habitat.toLowerCase().includes(filter));
    count.textContent = `엔티티 ${items.length}개`;
    items.forEach((e,i) => {
      html += `<div class="sidebar-item${currentIndex===i?' active':''}" onclick="showEntity(${e.num})">
        <span class="item-num">#${e.num}</span>
        <span class="item-name">${e.name}</span>
      </div>`;
    });
  } else if (currentTab === 'items') {
    items = ITEMS.filter(it => !filter ||
      it.name.toLowerCase().includes(filter) ||
      it.rarity.toLowerCase().includes(filter));
    count.textContent = `물품 ${items.length}개`;
    items.forEach((it,i) => {
      html += `<div class="sidebar-item${currentIndex===i?' active':''}" onclick="showItem(${it.num})">
        <span class="item-num">#${it.num}</span>
        <span class="item-name">${it.name}</span>
      </div>`;
    });
  } else if (currentTab === 'behinds') {
    items = BEHINDS.filter(b => !filter ||
      b.title.toLowerCase().includes(filter));
    count.textContent = `기밀 파일 ${items.length}개`;
    items.forEach((b,i) => {
      html += `<div class="sidebar-item${currentIndex===i?' active':''}" onclick="showBehind(${b.num})">
        <span class="item-num">0${b.num}</span>
        <span class="item-name">${b.title}</span>
      </div>`;
    });
  }
  list.innerHTML = html;
}

function filterList() {
  const val = document.getElementById('searchInput').value;
  renderList(val);
}

function showWelcome() {
  document.getElementById('welcomeScreen').style.display = 'flex';
  document.getElementById('entryCard').style.display = 'none';
}

function showContent(html) {
  document.getElementById('welcomeScreen').style.display = 'none';
  const card = document.getElementById('entryCard');
  card.style.display = 'block';
  card.innerHTML = html;
  card.scrollTop = 0;
}

function showLevel(num) {
  const l = LEVELS.find(x => x.num === num);
  if (!l) return;
  const tagCls = getTagClass(l.danger);
  const dangerCls = getDangerClass(l.danger);
  const html = `
    <div class="entry-header">
      <div class="entry-id">LEVEL DATABASE / ID: LEVEL-${String(l.num).padStart(3,'0')}</div>
      <div class="entry-title">Level ${l.num} — ${l.name}</div>
      <div class="entry-tags">
        <span class="tag ${tagCls}">위험 등급: ${l.danger}</span>
        <span class="tag tag-default">환경: ${l.env}</span>
        <span class="tag tag-default">엔티티율: ${l.entity_rate}</span>
        <span class="tag tag-default">자원: ${l.resources}</span>
      </div>
    </div>
    <div class="entry-section">
      <div class="entry-section-head">■ 상세 서술</div>
      <div class="entry-section-body">${nl2br(l.desc)}</div>
    </div>
    <div class="entry-section">
      <div class="entry-section-head">■ 지리적 구역 분석</div>
      <div class="entry-section-body">${nl2br(l.geo)}</div>
    </div>
    <div class="entry-section">
      <div class="entry-section-head">■ 서바이벌 프로토콜 및 생존 전략</div>
      <div class="entry-section-body">${nl2br(l.survival)}</div>
    </div>`;
  showContent(html);
  setActiveItem('levels', num);
}

function showEntity(num) {
  const e = ENTITIES.find(x => x.num === num);
  if (!e) return;
  const dCls = getEntityDangerClass(e.danger);
  const html = `
    <div class="entry-header">
      <div class="entry-id">ENTITY DATABASE / CODE: ENTITY-${String(e.num).padStart(3,'0')}</div>
      <div class="entry-title">Entity #${e.num} — ${e.name}</div>
      <div class="entry-tags">
        <span class="tag ${e.danger.includes('Inhuman')||e.danger.includes('최상급')?'tag-danger-5':e.danger.includes('Hostile')||e.danger.includes('위험')?'tag-danger-4':'tag-danger-1'}">${e.danger}</span>
        <span class="tag tag-default">서식지: ${e.habitat}</span>
      </div>
    </div>
    <div class="entry-section">
      <div class="entry-section-head">■ 신체 특징</div>
      <div class="entry-section-body">${nl2br(e.body)}</div>
    </div>
    <div class="entry-section">
      <div class="entry-section-head">■ 행동 양식 및 생태 정보</div>
      <div class="entry-section-body">${nl2br(e.behavior)}</div>
    </div>
    <div class="entry-section">
      <div class="entry-section-head">■ 전술적 대책 가이드</div>
      <div class="entry-section-body">${nl2br(e.tactic)}</div>
    </div>`;
  showContent(html);
  setActiveItem('entities', num);
}

function showItem(num) {
  const it = ITEMS.find(x => x.num === num);
  if (!it) return;
  const rareCls = it.rarity.includes('Rare') || it.rarity.includes('귀중') ? 'item-rare' : 'item-common';
  const html = `
    <div class="entry-header">
      <div class="entry-id">ITEM ARCHIVE / CODE: ITEM-${String(it.num).padStart(3,'0')}</div>
      <div class="entry-title">${it.name}</div>
      <div class="entry-tags">
        <span class="tag ${it.rarity.includes('Rare')||it.rarity.includes('귀중')?'tag-danger-2':'tag-danger-0'}">희귀도: ${it.rarity}</span>
      </div>
    </div>
    <div class="entry-section">
      <div class="entry-section-head">■ 주요 효능</div>
      <div class="entry-section-body">${nl2br(it.effect)}</div>
    </div>
    <div class="entry-section">
      <div class="entry-section-head">■ 보관 요령</div>
      <div class="entry-section-body">${nl2br(it.storage)}</div>
    </div>`;
  showContent(html);
  setActiveItem('items', num);
}

function showBehind(num) {
  const b = BEHINDS.find(x => x.num === num);
  if (!b) return;
  const html = `
    <div class="entry-header">
      <div class="entry-id">CLASSIFIED FILE / CODE: BEHIND-0${b.num}</div>
      <div class="entry-title">비하인드 파일 0${b.num}: ${b.title}</div>
      <div class="entry-tags">
        <span class="tag tag-danger-5">⚠ 극비 문서 — 무단 열람 금지</span>
      </div>
    </div>
    <div class="entry-section">
      <div class="entry-section-head">■ 기밀 내용</div>
      <div class="entry-section-body">
        <div class="classified-stamp">TOP SECRET</div><br>
        <div class="behind-content">${nl2br(b.content)}</div>
      </div>
    </div>`;
  showContent(html);
  setActiveItem('behinds', num);
}

function setActiveItem(tab, num) {
  document.querySelectorAll('.sidebar-item').forEach(el => el.classList.remove('active'));
  const items = document.querySelectorAll('.sidebar-item');
  // Re-highlight correct item
  let arr = tab==='levels'?LEVELS:tab==='entities'?ENTITIES:tab==='items'?ITEMS:BEHINDS;
  const filter = document.getElementById('searchInput').value.toLowerCase();
  let filtered;
  if (tab==='levels') filtered = arr.filter(l => !filter || ('level '+l.num).includes(filter)||l.name.toLowerCase().includes(filter)||l.danger.toLowerCase().includes(filter));
  else if (tab==='entities') filtered = arr.filter(e => !filter||('entity #'+e.num).includes(filter)||e.name.toLowerCase().includes(filter)||e.danger.toLowerCase().includes(filter)||e.habitat.toLowerCase().includes(filter));
  else if (tab==='items') filtered = arr.filter(it => !filter||it.name.toLowerCase().includes(filter)||it.rarity.toLowerCase().includes(filter));
  else filtered = arr.filter(b => !filter||b.title.toLowerCase().includes(filter));
  
  const idx = filtered.findIndex(x => x.num === num);
  if (idx >= 0 && items[idx]) items[idx].classList.add('active');
}

// Init
renderList();
</script>
